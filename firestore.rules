rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "lumaphotographstudio@gmail.com" && 
        request.auth.token.email_verified == true;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['name', 'email', 'service', 'message', 'createdAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.email is string && data.email.size() > 3 && data.email.size() < 100 &&
        data['service'] is string && data['service'].size() > 0 &&
        data.message is string && data.message.size() > 0 && data.message.size() < 2000 &&
        data.createdAt is string;
    }

    match /submissions/{submissionId} {
      allow create: if isValidSubmission(request.resource.data);
      allow read, delete: if isAdmin();
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
